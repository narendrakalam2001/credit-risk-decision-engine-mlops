data/Bank_Personal_Loan_Modelling.csv

# Sample files — push to GitHub (recruiters can see data structure)
# data/sample_credit_data.csv          ← intentionally NOT ignored
# data/sample_credit_data_balanced.csv ← intentionally NOT ignored

# ── Logs ──────────────────────────────────────────────────────
logs/*
!logs/prediction_logs.csv
*.log

# ── MLflow ────────────────────────────────────────────────────
mlruns/
mlartifacts/

